# Modern browsers that support ES2022+ features
# This eliminates polyfills for: Array.at, Array.flat, Object.hasOwn, etc.
# Reduces bundle size by ~14KB

# Chrome/Edge 92+ (2021)
chrome >= 92
edge >= 92

# Firefox 90+ (2021)
firefox >= 90

# Safari 15.4+ (2022) - iOS 15.4+
safari >= 15.4
ios >= 15.4

# Opera 78+ (2021)
opera >= 78

# Samsung Internet 15+ (2021)
samsung >= 15

# Exclude old/dead browsers
not dead
not IE 11
not op_mini all

# Market share filter
> 0.5%
